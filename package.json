{
  "name": "ironman",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-backend": "esbuild ./backend/index.ts --bundle --outfile=app.cjs --platform=node",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore src",
    "backend": "DEBUG=ironman:* ts-node --project ./node.tsconfig.json ./backend/index.ts",
    "backend-win": "@powershell -Command $env:DEBUG='ironman:*';ts-node --project ./node.tsconfig.json ./backend/index.ts"
  },
  "dependencies": {
    "@mdi/font": "5.9.55",
    "axios": "^1.7.2",
    "connect-history-api-fallback": "^1.6.0",
    "core-js": "^3.8.3",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "discord.js": "^14.21.0",
    "dotenv": "^16.0.1",
    "esbuild": "^0.25.8",
    "express": "^4.19.2",
    "express-session": "^1.17.3",
    "howler": "^2.2.4",
    "luxon": "^3.4.4",
    "memorystore": "^1.6.7",
    "roboto-fontface": "*",
    "vue": "^3.5.18",
    "vue-router": "^4.0.3",
    "vuetify": "^3.9.4",
    "webfontloader": "^1.0.0"
  },
  "devDependencies": {
    "@types/connect-history-api-fallback": "^1.5.4",
